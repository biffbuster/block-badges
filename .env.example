# ─── Server-only secrets (NEVER prefix with NEXT_PUBLIC_) ───

# Space and Time API key — get from https://console.spaceandtime.io
SXT_API_KEY=

# Neon PostgreSQL connection string
DATABASE_URL=

# Ethereum private key for minting SBTs (server-side only)
MINTER_PRIVATE_KEY=

# Base mainnet RPC (defaults to https://mainnet.base.org if empty)
BASE_RPC_URL=

# Deployed contract addresses (Base mainnet)
BLOCK_BADGE_ADDRESS=
BADGE_VERIFIER_ADDRESS=

# Basescan API key for contract verification
BASESCAN_API_KEY=

# ─── Client-safe public values (NEXT_PUBLIC_ prefix) ───

# WalletConnect project ID — get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Public contract addresses (on-chain, already public)
NEXT_PUBLIC_SXT_TOKEN_ADDRESS=0xE6Bfd33F52d82Ccb5b37E16D3dD81f9FFDAbB195
NEXT_PUBLIC_BADGE_VERIFIER_ADDRESS=
NEXT_PUBLIC_QUERY_ROUTER_ADDRESS=0x220a7036a815a1Bd4A7998fb2BCE608581fA2DbB
